#include <iostream>

int
main()
{
    int x = 4;
    int y = 33;
    int s = 0;
    std::cout << "SUM " << x;
    for (; y > 0; --y)
    {
        for (; x > 0; --x)
        {
            s += x;
        }
    }
    std::cout << " IS " << s << '\n';
    if (x > 100)
    {
        return 1;
    }
    return 0;
}
