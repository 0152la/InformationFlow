#include <iostream>

int
main(int argc, char** argv)
{
    int x = 4;
    int s = 0;
    std::cout << "SUM " << x;
    if (argc > 1)
    {
        return 0;
    }
    for (; x > 0; --x)
    {
        s += x;
    }
    std::cout << " IS " << s << '\n';
    if (x > 100)
    {
        return 1;
    }
    return 0;
}
